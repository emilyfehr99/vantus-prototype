{
    "framework": "vite",
    "buildCommand": "cd vantus-partner-site && npm install && npm run build",
    "outputDirectory": "vantus-partner-site/dist",
    "installCommand": "echo 'Install handled in buildCommand'",
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}