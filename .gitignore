# Ignore everything by default
*

# Unignore directories so we can traverse
!*/

# Unignore Vantus-specific project directories (recursively)
!vantus/**
!vantus-app/**
!vantus-dashboard/**
!bridge-server/**
!vantus-partner-site/**
!vantus-pilot-ios/**
!vantus-pilot-web/**

# Unignore system/config files
!.gitignore
!README.md
!README_VANTUS.md
!package.json
!vercel.json
!.github/**

# Explicitly ignore nested git repos/submodules that shouldn't be here
team-reports/

# Explicitly re-ignore common junk (even if inside allowed folders)
node_modules/
.DS_Store
.env
.env.local
*.log
dist/
build/
.next/
.expo/
coverage/

# Explicitly ignore known non-vantus projects (redundant with *, but safe)
automated-post-game-reports/
velocity-logic/
velocity-logic-agent/
velocity-logic-dashboard/
VelocityLogic_Staging/
nhl-analytics/
